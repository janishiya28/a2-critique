{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 700,
  "height": 400,

  "title": "Australian Test Wins Over Time",

  "data": {
    "url": "aus_team_results.csv"
  },

  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "size": 80
    },
    "color": "#0b6623",
    "strokeWidth": 3
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year"
    },

    "y": {
      "field": "Wins",
      "type": "quantitative",
      "title": "Wins"
    },

    "tooltip": [
      { "field": "Year", "title": "Year" },
      { "field": "Wins", "title": "Wins" }
    ]
  },

  "config": {
    "background": "white"
  }
}