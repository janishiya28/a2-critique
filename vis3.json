{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  
    "width": 800,
    "height": 500,
  
    "title": "Australia's Major Cricket Grounds",
  
    "projection": {
      "type": "mercator"
    },
  
    "layer": [
      {
        "data": {
          "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
          "format": {
            "type": "json"
          }
        },
  
        "mark": {
          "type": "geoshape",
          "fill": "#d9d9d9",
          "stroke": "white",
          "strokeWidth": 1
        }
      },
  
      {
        "data": {
          "url": "aus_grounds.csv"
        },
  
        "mark": {
          "type": "circle",
          "opacity": 0.85,
          "stroke": "#f4c542",
          "strokeWidth": 2
        },
  
        "encoding": {
          "longitude": {
            "field": "Longitude",
            "type": "quantitative"
          },
  
          "latitude": {
            "field": "Latitude",
            "type": "quantitative"
          },
  
          "size": {
            "field": "Matches",
            "type": "quantitative",
            "title": "Matches Hosted"
          },
  
          "color": {
            "value": "#0b6623"
          },
  
          "tooltip": [
            { "field": "Ground", "title": "Ground" },
            { "field": "City", "title": "City" },
            { "field": "Matches", "title": "Matches" }
          ]
        }
      }
    ],
  
    "config": {
      "background": "white"
    }
  }
